<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefWidth="900.0" prefHeight="600.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.project4_software.ChicagoStyleController">

    <children>

        <Label layoutX="320.0" layoutY="20.0"
               text="Chicago Style Pizza"
               style="-fx-font-size: 24px; -fx-font-weight: bold;" />

        <Label layoutX="60.0" layoutY="80.0" text="Pizza Type:" />
        <ComboBox fx:id="pizzaTypeBox"
                  layoutX="150.0" layoutY="75.0"
                  prefWidth="180.0"
                  onAction="#handlePizzaTypeChange" />

        <Label layoutX="60.0" layoutY="130.0" text="Size:" />

        <RadioButton fx:id="smallButton"
                     layoutX="150.0" layoutY="130.0"
                     text="Small"
                     onAction="#handleSizeChange">
            <toggleGroup>
                <ToggleGroup fx:id="sizeGroup" />
            </toggleGroup>
        </RadioButton>

        <RadioButton fx:id="mediumButton"
                     layoutX="230.0" layoutY="130.0"
                     text="Medium"
                     toggleGroup="$sizeGroup"
                     onAction="#handleSizeChange" />

        <RadioButton fx:id="largeButton"
                     layoutX="330.0" layoutY="130.0"
                     text="Large"
                     toggleGroup="$sizeGroup"
                     onAction="#handleSizeChange" />

        <Label layoutX="60.0" layoutY="180.0" text="Crust:" />
        <TextField fx:id="crustField"
                   layoutX="150.0" layoutY="175.0"
                   prefWidth="180.0"
                   editable="false" />

        <Label layoutX="60.0" layoutY="230.0" text="Price:" />
        <TextField fx:id="priceField"
                   layoutX="150.0" layoutY="225.0"
                   prefWidth="180.0"
                   editable="false" />

        <ImageView fx:id="pizzaImage"
                   layoutX="560.0" layoutY="70.0"
                   fitWidth="250.0" fitHeight="200.0"
                   preserveRatio="true" />

        <Label layoutX="60.0" layoutY="290.0" text="Available Toppings:" />
        <ListView fx:id="availableToppingsList"
                  layoutX="60.0" layoutY="320.0"
                  prefWidth="180.0" prefHeight="180.0" />

        <Button fx:id="addToppingButton"
                layoutX="270.0" layoutY="360.0"
                prefWidth="130.0"
                text="Add Topping"
                onAction="#handleAddTopping" />

        <Button fx:id="removeToppingButton"
                layoutX="270.0" layoutY="410.0"
                prefWidth="130.0"
                text="Remove Topping"
                onAction="#handleRemoveTopping" />

        <Label layoutX="430.0" layoutY="290.0" text="Selected Toppings:" />
        <ListView fx:id="selectedToppingsList"
                  layoutX="430.0" layoutY="320.0"
                  prefWidth="180.0" prefHeight="180.0" />

        <Button fx:id="addToOrderButton"
                layoutX="650.0" layoutY="360.0"
                prefWidth="150.0"
                text="Add to Order"
                onAction="#handleAddToOrder" />

        <Button fx:id="mainMenuButton"
                layoutX="650.0" layoutY="420.0"
                prefWidth="150.0"
                text="Main Menu"
                onAction="#handleMainMenu" />

    </children>
</AnchorPane>
