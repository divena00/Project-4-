<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.project4_software.MainController"
            prefWidth="670.0" prefHeight="710.0"
            style="-fx-background-color: #eef5f4;">

    <top>
        <VBox spacing="0">
            <children>
                <StackPane prefHeight="80.0"
                           style="-fx-background-color: #3aa0ef;">
                    <children>
                        <Label text="RU PIZZA"
                               style="-fx-text-fill: white; -fx-font-size: 42px; -fx-font-family: 'Comic Sans MS'; -fx-font-weight: bold;"/>
                    </children>
                </StackPane>
            </children>
        </VBox>
    </top>

    <center>
        <GridPane hgap="28.0" vgap="18.0" padding="25.0">
            <columnConstraints>
                <ColumnConstraints percentWidth="50.0"/>
                <ColumnConstraints percentWidth="50.0"/>
            </columnConstraints>
            <rowConstraints>
                <RowConstraints percentHeight="50.0"/>
                <RowConstraints percentHeight="50.0"/>
            </rowConstraints>

            <children>

                <!-- Chicago -->
                <Button onAction="#openChicagoPizzaView"
                        prefWidth="280.0" prefHeight="235.0"
                        style="-fx-background-color: #d9b3f3; -fx-background-radius: 6; -fx-cursor: hand;"
                        GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <graphic>
                        <VBox alignment="CENTER" spacing="10">
                            <children>
                                <ImageView fitWidth="225.0" fitHeight="160.0" preserveRatio="false">
                                    <image>
                                        <Image url="@chicago-byo.png"/>
                                    </image>
                                </ImageView>
                                <Label text="Chicago Style"
                                       style="-fx-text-fill: white; -fx-font-size: 16px;"/>
                            </children>
                        </VBox>
                    </graphic>
                </Button>

                <!-- NY -->
                <Button onAction="#openNYPizzaView"
                        prefWidth="280.0" prefHeight="235.0"
                        style="-fx-background-color: black; -fx-background-radius: 6; -fx-cursor: hand;"
                        GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <graphic>
                        <VBox alignment="CENTER" spacing="10">
                            <children>
                                <ImageView fitWidth="225.0" fitHeight="160.0" preserveRatio="false">
                                    <image>
                                        <Image url="@ny-byo.png"/>
                                    </image>
                                </ImageView>
                                <Label text="NY Style"
                                       style="-fx-text-fill: white; -fx-font-size: 16px;"/>
                            </children>
                        </VBox>
                    </graphic>
                </Button>

                <!-- Orders placed -->
                <Button onAction="#openStoreOrdersView"
                        prefWidth="280.0" prefHeight="235.0"
                        style="-fx-background-color: black; -fx-background-radius: 6; -fx-cursor: hand;"
                        GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <graphic>
                        <VBox alignment="CENTER" spacing="10">
                            <children>
                                <ImageView fitWidth="225.0" fitHeight="160.0" preserveRatio="false">
                                    <image>
                                        <Image url="orders-icon.png"/>
                                    </image>
                                </ImageView>
                                <Label text="Orders Placed"
                                       style="-fx-text-fill: white; -fx-font-size: 16px;"/>
                            </children>
                        </VBox>
                    </graphic>
                </Button>

                <!-- Current order -->
                <Button onAction="#openCurrentOrderView"
                        prefWidth="280.0" prefHeight="235.0"
                        style="-fx-background-color: black; -fx-background-radius: 6; -fx-cursor: hand;"
                        GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <graphic>
                        <VBox alignment="CENTER" spacing="10">
                            <children>
                                <ImageView fitWidth="225.0" fitHeight="160.0" preserveRatio="false">
                                    <image>
                                        <Image url="cart-icon.png"/>
                                    </image>
                                </ImageView>
                                <Label text="Current Order"
                                       style="-fx-text-fill: white; -fx-font-size: 16px;"/>
                            </children>
                        </VBox>
                    </graphic>
                </Button>

            </children>
        </GridPane>
    </center>

</BorderPane>
