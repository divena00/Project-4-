<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.project4_software.MainController"
      prefWidth="600.0" prefHeight="450.0">

    <padding>
        <Insets top="30.0" right="30.0" bottom="30.0" left="30.0"/>
    </padding>

    <children>

        <Label text="RU Pizza Ordering System"
               style="-fx-font-size: 24px; -fx-font-weight: bold;" />

        <Label text="Welcome! Please choose an option below."
               style="-fx-font-size: 16px;" />

        <Separator prefWidth="300.0" />

        <Label text="Select Pizza Style:"
               style="-fx-font-size: 16px; -fx-font-weight: bold;" />

        <Button text="New York Style Pizza"
                prefWidth="220.0"
                prefHeight="40.0"
                onAction="#openNYPizzaView" />

        <Button text="Chicago Style Pizza"
                prefWidth="220.0"
                prefHeight="40.0"
                onAction="#openChicagoPizzaView" />

        <Separator prefWidth="300.0" />

        <Label text="Order Management:"
               style="-fx-font-size: 16px; -fx-font-weight: bold;" />

        <Button text="Current Order"
                prefWidth="220.0"
                prefHeight="40.0"
                onAction="#openCurrentOrderView" />

        <Button text="Store Orders"
                prefWidth="220.0"
                prefHeight="40.0"
                onAction="#openStoreOrdersView" />

    </children>
</VBox>
